    S5["SLV_CLAIM<br/>(claim_sk, patient_sk, patient_id, insurance_id, claim_amount, claim_status, claim_date, source_ingestion_timestamp)"]
  end

  Bronze -->|LOAD_SLV_* procedures| Silver

  subgraph Gold["Gold (Business-ready)"]
    G1["DIM_PATIENT<br/>(patient_sk, patient_id, patient_name, age, gender, city, state)"]
